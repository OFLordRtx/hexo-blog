<article class="article-shell">
  <header class="article-header">
    <p class="article-route">
      <a href="<%- url_for('/') %>">FIELD NOTES</a>
      <span aria-hidden="true">/</span>
      <% if (page.categories && page.categories.length) { %>
        <% const category = page.categories.first(); %>
        <a href="<%- url_for(category.path) %>"><%= category.name %></a>
      <% } else { %>
        <span>未分类</span>
      <% } %>
    </p>
    <h1><%= page.title %></h1>
    <div class="article-meta">
      <span>发布 <time datetime="<%= date_xml(page.date) %>"><%= date(page.date, 'YYYY.MM.DD') %></time></span>
      <% if (page.updated && page.updated.valueOf() !== page.date.valueOf()) { %>
        <span>更新 <time datetime="<%= date_xml(page.updated) %>"><%= date(page.updated, 'YYYY.MM.DD') %></time></span>
      <% } %>
    </div>
  </header>

  <div class="article-grid">
    <aside class="article-rail" aria-hidden="true">
      <span></span>
      <small>READ / VERIFY / REPEAT</small>
    </aside>
    <div class="article-content">
      <%- page.content %>
    </div>
  </div>

  <footer class="article-footer">
    <% if (page.tags && page.tags.length) { %>
      <ul class="tag-list" aria-label="文章标签">
        <% page.tags.each(function(tag) { %>
          <li><a href="<%- url_for(tag.path) %>">#<%= tag.name %></a></li>
        <% }); %>
      </ul>
    <% } %>

    <nav class="post-navigation" aria-label="相邻文章">
      <% if (page.prev) { %>
        <a href="<%- url_for(page.prev.path) %>">
          <small>上一篇</small>
          <strong><%= page.prev.title %></strong>
        </a>
      <% } %>
      <% if (page.next) { %>
        <a href="<%- url_for(page.next.path) %>">
          <small>下一篇</small>
          <strong><%= page.next.title %></strong>
        </a>
      <% } %>
    </nav>
  </footer>
</article>
